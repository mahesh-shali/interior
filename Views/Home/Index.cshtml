@{
    ViewData["Title"] = "Home Page";
}

@section Hero {
    <section class="hero d-flex align-items-center justify-content-center text-center text-white">
        <div>
            <h1>Precise concept design for stylish living</h1>
            <p>Modern interior solutions</p>
            <a class="btn btn-warning">Get Started</a>
        </div>
    </section>
}

@model HomeViewModel

<section class="offer-section py-5">
    <div class="container text-center">
        
        <h2 class="fw-bold mb-3">What we offer to our clients</h2>
        <p class="text-muted mb-5">
            Who are in extremely love with eco friendly system..
        </p>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="offer-card p-4">
                    <h5 class="fw-bold">Interior Design</h5>
                    <p class="text-muted">
                        Sony laptops are among the most well known laptops on today's market.
                        Sony is a name that over time has established itself.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="offer-card p-4">
                    <h5 class="fw-bold">Architecture Design</h5>
                    <p class="text-muted">
                        Computer users and programmers have become so accustomed to using Windows,
                        even for the changing capabilities.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="offer-card p-4">
                    <h5 class="fw-bold">Concept Design</h5>
                    <p class="text-muted">
                        Can you imagine what we will be downloading in another twenty years?
                        I mean who would have thought that.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>
<section class="portfolio-section py-5">
    <div class="container text-center">

        <h2 class="fw-bold mb-2">Our Recent Works may impress you</h2>
        <p class="text-muted mb-5">Who are in extremely love with eco friendly system.</p>

        <div class="row g-4">

            <!-- BIG IMAGE -->
            <div class="col-md-8">
                <div class="portfolio-item">
                    <img src="~/images/p1.jpg" asp-append-version="true" class="img-fluid rounded" alt="Modern living room interior" />

                    <div class="overlay">
                        <h5>Lavendar ambient interior</h5>
                        <a class="btn btn-warning mt-3">More Details</a>
                    </div>
                </div>
            </div>

            <!-- SMALL IMAGE -->
            <div class="col-md-4">
                <div class="portfolio-item">
                    <img src="~/images/p2.jpg" asp-append-version="true" class="img-fluid rounded" alt="Bright minimalist interior" />
                </div>
            </div>

            <!-- SMALL -->
            <div class="col-md-4">
                <div class="portfolio-item">
                    <img src="~/images/p3.jpg" asp-append-version="true" class="img-fluid rounded" alt="Kitchen design detail" />
                </div>
            </div>

            <!-- BIG -->
            <div class="col-md-8">
                <div class="portfolio-item">
                    <img src="~/images/p4.jpg" asp-append-version="true" class="img-fluid rounded" alt="Colorful contemporary living space" />
                </div>
            </div>

        </div>
    </div>
</section>

<section class="features-section py-5 text-center text-white">
    <div class="container">

        <h2 class="fw-bold mb-2">Some Features that Made us Unique</h2>
        <p class="mb-5">Who are in extremely love with eco friendly system.</p>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-person"></i>
                    <h5>Expert Technicians</h5>
                    <p>Computer users and programmers have become so accustomed to using Windows.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-briefcase"></i>
                    <h5>Professional Service</h5>
                    <p>Finding the perfect learning tool is a daunting task to any novice developer.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-headset"></i>
                    <h5>Great Support</h5>
                    <p>While most people enjoy gaming and sports betting for excitement.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-lightning"></i>
                    <h5>Technical Skills</h5>
                    <p>The moment you think of buying a web hosting plan, you know one thing.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card featured">
                    <i class="bi bi-gem"></i>
                    <h5>Highly Recommended</h5>
                    <p>Many colleges are now offering online courses which are the exact same.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-chat-dots"></i>
                    <h5>Positive Reviews</h5>
                    <p>So you have your new digital camera and clicking away to glory.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="testimonial-section py-5 text-center">
    <div class="container">

        <h2 class="fw-bold mb-2">Testimonial from our Clients</h2>
        <p class="text-muted mb-5">Who are in extremely love with eco friendly system.</p>

        <div class="row g-4 justify-content-center">

            @if (Model?.Testimonials != null && Model.Testimonials.Count > 0)
            {
                foreach (var item in Model.Testimonials)
                {
                    <div class="col-md-5">
                        <div class="testimonial-card p-4 text-start">

                            <div class="mb-3">
                                <h6 class="mb-1 fw-bold">@item.Name</h6>

                                <!-- Rating -->
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="star @(i <= item.Rating ? "filled" : "")">★</span>
                                    }
                                </div>
                            </div>

                            <p class="text-muted">@item.Message</p>

                        </div>
                    </div>
                }
            }
            else
            {
                <p>No testimonials available</p>
            }

        </div>

    </div>
</section>

<section class="exhibition-section py-5 text-center">
    <div class="container">

        <h2 class="fw-bold mb-2">Ongoing Exhibitions from the scratch</h2>
        <p class="text-muted mb-5">Who are in extremely love with eco friendly system.</p>

        <div id="exhibitionCarousel" class="carousel slide" data-bs-ride="carousel">

            <!-- Indicators -->
            <div class="carousel-indicators">
                @{
                    int slideCount = (int)Math.Ceiling(Model.Exhibitions.Count / 3.0);
                    for (int i = 0; i < slideCount; i++)
                    {
                        <button type="button"
                                data-bs-target="#exhibitionCarousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")">
                        </button>
                    }
                }
            </div>

            <!-- Slides -->
            <div class="carousel-inner">

                @for (int i = 0; i < Model.Exhibitions.Count; i += 3)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <div class="row g-4 justify-content-center">

                            @for (int j = i; j < i + 3 && j < Model.Exhibitions.Count; j++)
                            {
                                var item = Model.Exhibitions[j];

                                <div class="col-md-4">
                                    <div class="exhibition-card h-100">

                                        <img src="@item.ImageUrl" class="img-fluid rounded mb-3" />

                                        <div class="mb-2">
                                            @foreach (var tag in item.Tags)
                                            {
                                                <span class="badge bg-light text-dark me-1">@tag</span>
                                            }
                                        </div>

                                        <h5 class="fw-bold">@item.Title</h5>

                                        <p class="text-muted">@item.Description</p>

                                        <small class="text-muted">
                                            @item.Date.ToString("dd MMMM, yyyy")
                                        </small>

                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                }

            </div>

            <!-- ✅ ADD THIS: PREV BUTTON -->
            <button class="carousel-control-prev" type="button"
                    data-bs-target="#exhibitionCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <!-- ✅ ADD THIS: NEXT BUTTON -->
            <button class="carousel-control-next" type="button"
                    data-bs-target="#exhibitionCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>

    </div>
</section>