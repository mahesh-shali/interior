@{
    ViewData["Title"] = "Uploads";
}

@model List<CloudinaryDotNet.Actions.Resource>

<div class="container py-5">
    <h2 class="fw-bold mb-3">Uploads Page</h2>

    <!-- Logout -->
    <form asp-controller="Auth" asp-action="Logout" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Logout</button>
    </form>

    <!-- Upload -->
    <div class="mt-4">
        <form asp-controller="Upload" asp-action="UploadFile" method="post" enctype="multipart/form-data">
            <input type="file" name="file" required />
            <button type="submit" class="btn btn-primary">Upload</button>
        </form>
    </div>

    <!-- Preview last upload -->
    @if (ViewBag.Url != null)
    {
        var url = ViewBag.Url.ToString();

        <div class="mt-4">
            <h5>Last Uploaded</h5>

            @if (url.Contains("/video/"))
            {
                <video width="400" controls>
                    <source src="@url" type="video/mp4" />
                </video>
            }
            else
            {
                <img src="@url" width="300" />
            }
        </div>
    }

    <!-- Media Library -->
    <div class="mt-5">
        <h3>Media Library</h3>

        @if (Model != null && Model.Any())
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card p-2">

                            @if (item.ResourceType == "video")
                            {
                                <video width="100%" controls>
                                    <source src="@item.SecureUrl" type="video/mp4" />
                                </video>
                            }
                            else
                            {
                                <img src="@item.SecureUrl" class="img-fluid" />
                            }

                            <form asp-controller="Media" asp-action="Delete" method="post" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="publicId" value="@item.PublicId" />
                                <input type="hidden" name="resourceType" value="@item.ResourceType" />
                                <button class="btn btn-danger btn-sm w-100">Delete</button>
                            </form>

                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>No media found.</p>
        }
    </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">

    @if (ViewBag.Success != null)
    {
        <div class="toast text-bg-success" id="successToast">
            <div class="d-flex">
                <div class="toast-body">@ViewBag.Success</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="toast text-bg-danger" id="errorToast">
            <div class="d-flex">
                <div class="toast-body">@ViewBag.Error</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const successToast = document.getElementById('successToast');
        const errorToast = document.getElementById('errorToast');

        if (successToast) {
            new bootstrap.Toast(successToast, { delay: 3000 }).show();
        }

        if (errorToast) {
            new bootstrap.Toast(errorToast, { delay: 3000 }).show();
        }
    });
</script>