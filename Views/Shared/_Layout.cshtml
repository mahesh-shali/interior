<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - website</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/website.styles.css" asp-append-version="true" />
</head>
<body class="">
    <header>
        <partial name="_Navbar" />
    </header>

 @RenderSection("Hero", required: false)

 <div class="container mt-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted mt-5">
        <div class="container">
            <section class="contact-section py-5">
                <div class="container">
                    <div class="row align-items-start">

                        <!-- LEFT SIDE: CONTACT INFO -->
                        <div class="col-md-4">

                            <div class="d-flex mb-4">
                                <div class="me-3 text-warning fs-4">
                                    <i class="bi bi-house"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Space Touch Interior</h6>
                                    <small class="text-muted">Kempapura chikkabanavara Hesaraghatta main Road Banglore 560090</small>
                                </div>
                            </div>

                            <div class="d-flex mb-4">
                                <div class="me-3 text-warning fs-4">
                                    <i class="bi bi-telephone"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">+91 9901219254</h6>
                                    <small class="text-muted">Mon to Fri 9am to 6 pm</small>
                                </div>
                            </div>

                            <div class="d-flex">
                                <div class="me-3 text-warning fs-4">
                                    <i class="bi bi-envelope"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">vinayskalagi149@gmail.com</h6>
                                    <small class="text-muted">Send us your query anytime!</small>
                                </div>
                            </div>

                        </div>

                        <!-- RIGHT SIDE: FORM -->
                        <div class="col-md-8">
                            <form asp-controller="Email" asp-action="Send" method="post">

                            <div class="row g-3">

                                <div class="col-md-6">
                                    <input type="text" name="Name" class="form-control" placeholder="Enter your name" required>
                                </div>

                                <div class="col-md-6">
                                    <input type="email" name="Email" class="form-control" placeholder="Enter email address" required>
                                </div>

                                <div class="col-md-6">
                                    <input type="text" name="Subject" class="form-control" placeholder="Enter your subject" required>
                                </div>

                                <div class="col-md-6">
                                    <textarea name="Message" class="form-control" rows="5" placeholder="Message" required></textarea>
                                </div>

                                <div class="col-12 text-end mt-3">
                                    <button type="submit" class="btn btn-warning px-4 py-2 rounded-pill">
                                        Send Message
                                    </button>
                                </div>

                            </div>

                        </form>
                        </div>

                    </div>
                </div>
            </section>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
